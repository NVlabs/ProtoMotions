diff --git a/robojudo/environment/mujoco_env.py b/robojudo/environment/mujoco_env.py
index c107829..0864981 100644
--- a/robojudo/environment/mujoco_env.py
+++ b/robojudo/environment/mujoco_env.py
@@ -53,6 +53,30 @@ class MujocoEnv(Environment):
         self.random_heading = cfg_env.random_heading
 
         self._apply_random_heading()
+
+        # Virtual gantry: spring-damper that holds the robot near an anchor.
+        # Attaches to the highest-priority body found (upper body preferred
+        # so the robot hangs upright, like a real gantry).
+        self._gantry_enabled = False
+        self._gantry_anchor = None  # target position [3]
+        self._gantry_stiffness = 10000.0  # N/m — stiff enough to support ~50 kg
+        self._gantry_damping = 1000.0  # Ns/m — near-critical damping
+        _gantry_body_priority = [
+            "torso_link", "torso", "base_link", "pelvis", "Trunk", "Waist", "base",
+        ]
+        self._gantry_body_id = -1
+        for name in _gantry_body_priority:
+            bid = mujoco.mj_name2id(  # pyright: ignore[reportAttributeAccessIssue]
+                self.model, mujoco.mjtObj.mjOBJ_BODY, name
+            )
+            if bid >= 0:
+                self._gantry_body_id = bid
+                self._gantry_body_name = name
+                break
+        if self._gantry_body_id < 0:
+            logger.warning("Virtual gantry: no suitable body found, gantry disabled")
+            self._gantry_body_name = None
+
         self.update()  # get initial state
 
     def _apply_random_heading(self):
@@ -68,6 +92,50 @@ class MujocoEnv(Environment):
         self.data.qpos[5] = c * q[2] + s * q[1]
         self.data.qpos[6] = c * q[3] + s * q[0]
 
+    def enable_gantry(self):
+        """Attach a spring-damper to the gantry body at its current position."""
+        if self._gantry_body_id < 0:
+            logger.warning("No gantry body — skipping enable")
+            return
+        # xpos holds world-frame positions for each body after mj_forward.
+        self._gantry_anchor = self.data.xpos[self._gantry_body_id].copy()
+        self._gantry_enabled = True
+        logger.info(
+            f"Virtual gantry enabled on '{self._gantry_body_name}' "
+            f"at {self._gantry_anchor} "
+            f"(k={self._gantry_stiffness}, c={self._gantry_damping})"
+        )
+
+    def disable_gantry(self):
+        """Release the root body to free dynamics."""
+        self._gantry_enabled = False
+        # Clear any residual applied force.
+        self.data.xfrc_applied[self._gantry_body_id, :] = 0.0
+        logger.info("Virtual gantry disabled")
+
+    def _apply_gantry_force(self):
+        """Compute and apply spring-damper force on the gantry body."""
+        bid = self._gantry_body_id
+        pos = self.data.xpos[bid]  # world-frame position of the body
+        # cvel is [ang(3), lin(3)] in world frame for each body.
+        vel = self.data.cvel[bid, 3:]  # linear velocity
+
+        dx = self._gantry_anchor - pos
+        distance = np.linalg.norm(dx)
+        if distance < 1e-8:
+            # Already at anchor — just apply damping.
+            force = -self._gantry_damping * vel
+        else:
+            direction = dx / distance
+            v_radial = np.dot(vel, direction)
+            force = (
+                self._gantry_stiffness * distance - self._gantry_damping * v_radial
+            ) * direction
