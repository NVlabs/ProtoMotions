From 9b7aef15e5414d7b21032874fbbae3c7a6884ab4 Mon Sep 17 00:00:00 2001
From: Chen Tessler <ctessler@nvidia.com>
Date: Fri, 27 Feb 2026 10:34:29 -0800
Subject: [PATCH 09/16] fix action history feedback with deploy-time accel
 clamp

The model was trained without accel clamp, so historical.processed_actions
must contain the raw ONNX output. Post-processing (accel clamp, EMA) only
affects what goes to the simulator, not the feedback to the model.
Previously the clamped value was fed back, causing a mismatch that made
the model overcorrect.

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
Signed-off-by: Chen Tessler <ctessler@nvidia.com>
---
 robojudo/policy/protomotions_bm_tracker_policy.py | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git a/robojudo/policy/protomotions_bm_tracker_policy.py b/robojudo/policy/protomotions_bm_tracker_policy.py
index 9004237..92e99f9 100644
--- a/robojudo/policy/protomotions_bm_tracker_policy.py
+++ b/robojudo/policy/protomotions_bm_tracker_policy.py
@@ -226,7 +226,13 @@ class ProtoMotionsBMTrackerPolicy(Policy):
         ort_out = self._session.run(self._onnx_out_names, onnx_inputs)
         pd_targets = ort_out[1].squeeze().copy()
 
-        # -- PD target acceleration clamp --
+        # Store the raw ONNX output as the action history feedback.
+        # This is what the model saw as "processed_actions" during training,
+        # so it must NOT include any deploy-time post-processing (accel
+        # clamp, EMA) that wasn't present during training.
+        self._prev_actions = pd_targets.copy()
+
+        # -- PD target acceleration clamp (deploy-time smoothing) --
         if (
             self._pd_target_max_accel is not None
             and self._prev_pd is not None
@@ -251,7 +257,6 @@ class ProtoMotionsBMTrackerPolicy(Policy):
             self._ema_prev = pd_targets.copy()
 
         self._stashed_pd_targets = pd_targets
-        self._prev_actions = pd_targets.copy()
         extras = {}
         dummy_obs = np.zeros(1, dtype=np.float32)
         return dummy_obs, extras
-- 
