From 03bbdad6993db8a7714e5c1b50f4bdcbe1348c94 Mon Sep 17 00:00:00 2001
From: Chen Tessler <ctessler@nvidia.com>
Date: Fri, 27 Feb 2026 09:19:09 -0800
Subject: [PATCH 02/16] implement heading-alignment helpers locally

compute_yaw_offset_np and apply_heading_offset_np were imported from
deployment.state_utils but never existed there. Implement them as local
pure-NumPy quaternion helpers in the policy file to remove the missing
dependency.

Co-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>
Signed-off-by: Chen Tessler <ctessler@nvidia.com>
---
 .../policy/protomotions_tracker_policy.py     | 67 +++++++++++++++++--
 1 file changed, 63 insertions(+), 4 deletions(-)

diff --git a/robojudo/policy/protomotions_tracker_policy.py b/robojudo/policy/protomotions_tracker_policy.py
index 6580794..6fd4159 100644
--- a/robojudo/policy/protomotions_tracker_policy.py
+++ b/robojudo/policy/protomotions_tracker_policy.py
@@ -40,10 +40,6 @@ if _PROTO_ROOT not in sys.path:
     sys.path.insert(0, _PROTO_ROOT)
 
 from deployment.motion_utils import MotionPlayer
-from deployment.state_utils import (
-    apply_heading_offset_np,
-    compute_yaw_offset_np,
-)
 from robojudo.policy import Policy, policy_registry
 from robojudo.policy.policy_cfgs import PolicyCfg
 from robojudo.tools.tool_cfgs import DoFConfig
@@ -51,6 +47,69 @@ from robojudo.tools.tool_cfgs import DoFConfig
 logger = logging.getLogger(__name__)
 
 
+# ---------------------------------------------------------------------------
+# Heading-alignment helpers (pure NumPy, xyzw convention)
+# ---------------------------------------------------------------------------
+
+
+def _quat_yaw_only_np(q_xyzw: np.ndarray) -> np.ndarray:
+    """Project a quaternion to yaw-only (rotation about world Z)."""
+    x, y, z, w = q_xyzw[..., 0], q_xyzw[..., 1], q_xyzw[..., 2], q_xyzw[..., 3]
+    yaw_w = w.copy()
+    yaw_z = z.copy()
+    norm = np.sqrt(yaw_w**2 + yaw_z**2) + 1e-8
+    out = np.zeros_like(q_xyzw)
+    out[..., 2] = yaw_z / norm
+    out[..., 3] = yaw_w / norm
+    return out
+
+
+def _quat_conjugate_np(q_xyzw: np.ndarray) -> np.ndarray:
+    """Return the conjugate (inverse for unit quaternions), xyzw convention."""
+    conj = q_xyzw.copy()
+    conj[..., :3] *= -1.0
+    return conj
+
+
+def _quat_mul_np(a: np.ndarray, b: np.ndarray) -> np.ndarray:
+    """Hamilton product of two quaternions in xyzw convention."""
+    ax, ay, az, aw = a[..., 0], a[..., 1], a[..., 2], a[..., 3]
+    bx, by, bz, bw = b[..., 0], b[..., 1], b[..., 2], b[..., 3]
+    out = np.empty_like(a)
+    out[..., 0] = aw * bx + ax * bw + ay * bz - az * by
+    out[..., 1] = aw * by - ax * bz + ay * bw + az * bx
+    out[..., 2] = aw * bz + ax * by - ay * bx + az * bw
+    out[..., 3] = aw * bw - ax * bx - ay * by - az * bz
+    return out
+
+
+def compute_yaw_offset_np(
+    robot_quat: np.ndarray, motion_quat: np.ndarray
+) -> np.ndarray:
+    """Compute a yaw-only offset that rotates the motion heading to match the robot.
+
+    Returns ``offset`` such that ``offset * motion_yaw == robot_yaw``.
+    """
+    robot_yaw = _quat_yaw_only_np(np.asarray(robot_quat, dtype=np.float32))
+    motion_yaw = _quat_yaw_only_np(np.asarray(motion_quat, dtype=np.float32))
+    return _quat_mul_np(robot_yaw, _quat_conjugate_np(motion_yaw))
+
+
+def apply_heading_offset_np(
+    offset: np.ndarray, body_rot: np.ndarray
+) -> np.ndarray:
+    """Pre-rotate an array of body quaternions by a yaw offset.
+
+    Args:
+        offset: Yaw-only quaternion ``[4]`` (xyzw).
+        body_rot: Body rotations ``[..., 4]`` (xyzw).
+
+    Returns:
+        Rotated body quaternions, same shape as *body_rot*.
+    """
+    return _quat_mul_np(offset, body_rot)
+
+
 @policy_registry.register
 class ProtoMotionsTrackerPolicy(Policy):
     """Policy that drives a ProtoMotions tracker via unified ONNX model.
-- 
